{
  "crons": [
    {
      "path": "/api/trial-reminder",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ],
  "functions": {
    "api/admin.js": {
      "maxDuration": 300
    },
    "api/send-system-email.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/admin/send-system-email", "destination": "/api/send-system-email" },
    { "source": "/api/admin/(.*)", "destination": "/api/admin?action=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
